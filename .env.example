# ====== 文本大模型，已实现 ======
OPENAI_API_KEY=你的-deepseek-api-key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://api.deepseek.com
LOG_LEVEL=INFO

# OpenAI 官方示例：
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ====== DashScope / 百炼统一配置 ======
# 视觉识别、ASR、TTS 可以共用这一个百炼 API Key。
DASHSCOPE_API_KEY=你的-百炼-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====== 视觉识别，已实现 ======
VISION_PROVIDER=dashscope
VISION_MODEL=qwen-vl-plus
# 可选覆盖项。通常不用写，默认复用 DASHSCOPE_BASE_URL。
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 可选覆盖项。通常不用写，默认复用 DASHSCOPE_API_KEY。
# VISION_API_KEY=你的-百炼-api-key
VISION_MIN_CONFIDENCE=0.60

# ====== ASR 语音识别，已实现 ======
# ESP32 仍然通过 HTTP 上传 WAV；后端内部调用百炼 Paraformer 实时识别。
ASR_PROVIDER=dashscope
ASR_MODEL=paraformer-realtime-v2
# 可选覆盖项。通常不用写，默认复用 DASHSCOPE_API_KEY。
# ASR_API_KEY=你的-百炼-api-key
# 每次发给 ASR SDK 的 PCM 数据大小。3200 bytes 约等于 100ms 的 16k/16-bit/mono 音频。
ASR_FRAME_BYTES=3200
# 默认不按真实录音速度等待，追求更快返回；如果服务商限速，可以改成 0.02 或 0.05。
ASR_FRAME_SLEEP_SECONDS=0
# 某些 ASR 参数需要透传给 dashscope.audio.asr.Recognition 时，可以放 JSON。
# ASR_EXTRA_KWARGS={"language_hints":["zh"]}

# ====== TTS 语音合成，已接入本地文本 pipeline ======
# Qwen3-TTS 默认调用百炼公共 API，只需要 DASHSCOPE_API_KEY。
TTS_PROVIDER=dashscope
TTS_API_STYLE=dashscope_qwen
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry
TTS_LANGUAGE_TYPE=Chinese
# TTS_API_KEY=你的-百炼-api-key
# 一般不用配 TTS_BASE_URL；默认请求：
# https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# 如果以后换私有 endpoint，可以完整覆盖：
# TTS_ENDPOINT=https://your-endpoint/services/aigc/multimodal-generation/generation
TTS_TIMEOUT_SECONDS=120
# 某些 TTS 服务商需要额外参数时，可以放 JSON。
# TTS_EXTRA_JSON={"input":{"text":"会被代码覆盖，不建议这样写"}}
# 如果 ffmpeg 不在 PATH，可以手动指定。真实 TTS 推荐安装 ffmpeg，用来统一转成 ESP32 WAV。
# FFMPEG_BIN=D:\tools\ffmpeg\bin\ffmpeg.exe

# ====== ESP32 /ai 设备协议，已实现 ======
# 本地联调可以临时打开模拟 ASR 文本，让 /ai/finish 后跳过真实语音识别。
# AI_MOCK_ASR_TEXT=这是什么
# 本地联调也可以临时打开模拟 LLM 回复，完全不请求模型，专门测试设备状态机。
# AI_MOCK_LLM_TEXT=这是一个本地模拟回答，用来测试设备端轮询和音频拉取。
# 默认调用真实 TTS；开启后会生成 16k/16-bit/mono PCM WAV 静音文件，只用于离线测试。
AI_ENABLE_MOCK_TTS=false
AI_MOCK_TTS_SECONDS=0.4
AI_NO_SPEECH_TEXT=我没有听清，请再说一遍。
AI_ASR_ERROR_TEXT=语音识别暂时不可用，请稍后再试。
AI_SILENCE_RMS_THRESHOLD=80
AI_MIN_SPEECH_SECONDS=0.2
