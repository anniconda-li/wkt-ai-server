# ====== 文本大模型，已实现 ======
OPENAI_API_KEY=你的-deepseek-api-key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://api.deepseek.com
LOG_LEVEL=INFO

# OpenAI 官方示例：
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ====== DashScope / 百炼统一配置 ======
# 视觉识别、ASR、TTS 可以共用这一个百炼 API Key。
DASHSCOPE_API_KEY=你的-百炼-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====== 视觉识别，已实现 ======
VISION_PROVIDER=dashscope
VISION_MODEL=qwen3.6-flash-2026-04-16
# 文物五选一只需要稳定 JSON，关闭思考可降低延迟。
VISION_ENABLE_THINKING=false
# 可选覆盖项。通常不用写，默认复用 DASHSCOPE_BASE_URL。
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 可选覆盖项。通常不用写，默认复用 DASHSCOPE_API_KEY。
# VISION_API_KEY=你的-百炼-api-key
VISION_MIN_CONFIDENCE=0.60
# 视觉请求至少保留 120 秒；代码会把更小的配置提升到 120 秒。
VISION_TIMEOUT_SECONDS=120
# 每台设备最多保留最近多少张上传图片，避免服务器磁盘一直增长。
MAX_SAVED_IMAGES_PER_DEVICE=10
# 相机 raw JPEG 上传连续多久没有新字节就返回 HTTP 408；这是空闲超时，不是整次上传总时长。
CAMERA_UPLOAD_IDLE_TIMEOUT_SECONDS=8
# X-Request-ID 幂等结果保存在 uploads 下的 SQLite；默认缓存 20 分钟、最多 1000 条。
# CAMERA_IDEMPOTENCY_DB_PATH=uploads/camera_idempotency.sqlite3
CAMERA_IDEMPOTENCY_TTL_SECONDS=1200
CAMERA_IDEMPOTENCY_MAX_RECORDS=1000
# 并发重试等待原请求最终结果的最长时间，应覆盖视觉识别时长。
CAMERA_IDEMPOTENCY_WAIT_TIMEOUT_SECONDS=180
CAMERA_IDEMPOTENCY_POLL_INTERVAL_SECONDS=0.1
# JPEG 分片会话和分片元数据复用上面的 SQLite；临时字节写入 uploads/camera_chunks。
# CAMERA_CHUNK_TEMP_DIR=uploads/camera_chunks
CAMERA_CHUNK_SESSION_TTL_SECONDS=600
CAMERA_CHUNK_COMPLETED_TTL_SECONDS=1200
CAMERA_CHUNK_MAX_SESSIONS=100
CAMERA_CHUNK_MAX_TEMP_BYTES=67108864
CAMERA_CHUNK_CLEANUP_INTERVAL_SECONDS=60

# ====== ASR 语音识别，已实现 ======
# ESP32 上传完整 WAV 或 AOP1/Opus 后，后端调用百炼 Qwen3-ASR-Flash 同步识别。
ASR_PROVIDER=dashscope
ASR_MODEL=qwen3-asr-flash-2026-02-10
# 主模型失败时回退到原有 Paraformer 链路；留空可禁用回退。
ASR_FALLBACK_MODEL=paraformer-realtime-v2
ASR_LANGUAGE=zh
ASR_ENABLE_ITN=false
ASR_TIMEOUT_SECONDS=60
# 可选覆盖项。通常不用写，默认复用 DASHSCOPE_API_KEY。
# ASR_API_KEY=你的-百炼-api-key
# 每次发给 ASR SDK 的 PCM 数据大小。3200 bytes 约等于 100ms 的 16k/16-bit/mono 音频。
ASR_FRAME_BYTES=3200
# 默认不按真实录音速度等待，追求更快返回；如果服务商限速，可以改成 0.02 或 0.05。
ASR_FRAME_SLEEP_SECONDS=0
# ASR 文本进入 LLM 前会按本地文物名做拼音近似纠错，例如“英国玉婴” -> “应国玉鹰”。
# 阈值越高越保守，越低越容易纠错但也更容易误改。
ASR_ARTIFACT_PHONETIC_THRESHOLD=0.86
# 某些 ASR 参数需要透传给 dashscope.audio.asr.Recognition 时，可以放 JSON。
# ASR_EXTRA_KWARGS={"language_hints":["zh"]}

# ====== TTS 语音合成，已接入本地文本 pipeline ======
# Qwen3-TTS 默认调用百炼公共 API，只需要 DASHSCOPE_API_KEY。
TTS_PROVIDER=dashscope
TTS_API_STYLE=dashscope_qwen
TTS_MODEL=qwen3-tts-flash-2025-11-27
TTS_VOICE=Cherry
TTS_LANGUAGE_TYPE=Chinese
# TTS_API_KEY=你的-百炼-api-key
# 一般不用配 TTS_BASE_URL；默认请求：
# https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# 如果以后换私有 endpoint，可以完整覆盖：
# TTS_ENDPOINT=https://your-endpoint/services/aigc/multimodal-generation/generation
TTS_TIMEOUT_SECONDS=120
# 某些 TTS 服务商需要额外参数时，可以放 JSON。
# TTS_EXTRA_JSON={"input":{"text":"会被代码覆盖，不建议这样写"}}
# 如果 ffmpeg 不在 PATH，可以手动指定。AOP1 Opus 解码和 TTS 音频格式统一都需要 ffmpeg。
# FFMPEG_BIN=D:\tools\ffmpeg\bin\ffmpeg.exe

# ====== ESP32 /ai 设备协议，已实现 ======
# 本地联调可以临时打开模拟 ASR 文本，让 /ai/finish 后跳过真实语音识别。
# AI_MOCK_ASR_TEXT=这是什么
# 本地联调也可以临时打开模拟 LLM 回复，完全不请求模型，专门测试设备状态机。
# AI_MOCK_LLM_TEXT=这是一个本地模拟回答，用来测试设备端轮询和音频拉取。
# 默认调用真实 TTS；开启后会生成 16k/16-bit/mono PCM WAV 静音文件，只用于离线测试。
AI_ENABLE_MOCK_TTS=false
AI_MOCK_TTS_SECONDS=0.4
AI_NO_SPEECH_TEXT=我没有听清，请再说一遍。
AI_ASR_ERROR_TEXT=语音识别暂时不可用，请稍后再试。
AI_SILENCE_RMS_THRESHOLD=80
AI_MIN_SPEECH_SECONDS=0.2
