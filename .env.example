# ====== Text LLM, implemented ======
OPENAI_API_KEY=your-deepseek-api-key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://api.deepseek.com
LOG_LEVEL=INFO

# OpenAI official example:
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ====== DashScope / Bailian shared config ======
# Vision / future ASR / future TTS can share this one API key.
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====== Vision recognition, implemented ======
VISION_PROVIDER=dashscope
VISION_MODEL=qwen-vl-plus
# Optional override. Usually leave this empty and reuse DASHSCOPE_BASE_URL.
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Optional override. Usually leave this empty and reuse DASHSCOPE_API_KEY.
# VISION_API_KEY=your-dashscope-api-key
VISION_MIN_CONFIDENCE=0.60

# ====== ASR / TTS placeholders, not implemented yet ======
ASR_PROVIDER=dashscope
ASR_MODEL=paraformer-realtime-v2
TTS_PROVIDER=dashscope
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry
